label-open-foreground = ${colors.red}
label-close =ÔÄć
label-close-foreground = ${colors.red}
label-separator =|
label-separator-foreground = ${colors.foreground}
menu-0-0 =Ô•í
menu-0-0-exec = reboot
menu-0-1 =Ô§§
menu-0-1-exec = poweroff
menu-0-2 =ÔúÖ
