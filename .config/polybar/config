[module/temperature]
type = internal/temperature
format = <ramp> <label>
format-underline = ${colors.orange}
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}
label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.alert}
ramp-0 =Ôįē
ramp-1 =Ôõ≤
ramp-2 =ÓéŅ
