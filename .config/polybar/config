animation-charging-0 =ÔĖÖ
animation-charging-1 =ÔĖÜ
animation-charging-2 =ÔĖá
animation-charging-3 =ÔĖą
animation-charging-4 =ÔĖČ
animation-charging-5 =ÔĖä
animation-charging-6 =ÔĖĄ
animation-charging-foreground = ${colors.foreground}
