[colors]
background = #282828
background-alt = #3c3836
foreground = #fbf1c7
foreground-alt = #ebdbb2
alert = #cc241d
; gruvbox colors
red = #cc241d
green = #98971a
yellow = #d79921
blue = #458588
purple = #b16286
aqua = #689d6a
orange = #d65d0e


[bar/top]
monitor = ${env:MONITOR:}
width = 100%
height = 27
radius = 6.0
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 3 ; Coloured line below modules
border-size = 4
; leave space for systray
padding-right = 1
module-margin = 1
font-0 = UbuntuMono Nerd Font:size=12
modules-left = i3
modules-center = backlight date alsa
modules-right = wlan eth cpu memory battery temperature powermenu
tray-position = right
; workaround to get radius working on systray
;tray-detached = true
;tray-offset-x = -6
;tray-padding = 1

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false
label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.background}
; focused = Active workspace on focused monitor
label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.green}
label-focused-padding = 2
; unfocused = Inactive workspace on any monitor
label-unfocused = %index%
label-unfocused-padding = 2
; visible = Active workspace on unfocused monitor
label-visible = %index%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}
; urgent = Workspace with urgency hint set
label-urgent = %index%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2
label-separator = |

[module/backlight]
type = internal/backlight
card = intel_backlight
format = <ramp> <label>
label = %percentage%
ramp-0 =Ôóô
ramp-1 =Ôóö
ramp-2 =Ôóõ
ramp-3 =Ôóú
ramp-4 =ÔóĚ
ramp-5 =Ôóě
ramp-6 =Ôóü

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ÓČŅ "
format-prefix-foreground = ${colors.foreground}
format-underline = ${colors.purple}
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix ="Ô¨ô "
format-prefix-foreground = ${colors.foreground}
format-underline = ${colors.yellow}
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp1s0
interval = 1
format-connected = <label-connected>
format-connected-underline = ${colors.blue}
extra-label = extra
; TODO: make module clickable to change format on click
label-connected =%{A1:cmd_goes_here:}Ôáę %{A} %essid%: Ôõô %downspeed% | Ô©Ď %upspeed%

[module/eth]
type = internal/network
interface = enp2s0
interval = 1
format-connected = <label-connected>
format-connected-underline = #55aa55
format-connected-prefix-foreground = ${colors.foreground}
label-connected =ÔúÄ %local_ip%: Ôõô %downspeed% | Ô©Ď %upspeed%

[module/date]
type = internal/date
interval = 1
date-alt =%A %b %d
time =%H:%M
time-alt = %H:%M:%S
format-prefix ="ÔôŹ "
format-prefix-foreground = ${colors.foreground}
format-underline = ${colors.red}
label = %date% %time%

[module/alsa]
type = internal/alsa
format-volume = <ramp-volume> <label-volume>
label-volume = %percentage%
ramp-volume-0 =Ô©ĺ
ramp-volume-1 =Ô©Ņ
ramp-volume-2 =Ô©Ĺ
label-volume-foreground = ${colors.foreground}
format-muted-foreground = ${colors.foreground-alt}
label-muted =ÔĪĚ %percentage%

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 98
format-charging = <animation-charging> <label-charging>
format-charging-underline = ${colors.aqua}
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}
format-full-prefix =Ôēł
format-full-prefix-foreground = ${colors.foreground}
format-full-underline = ${self.format-charging-underline}
ramp-capacity-0 =ÔĖć
ramp-capacity-1 =ÔēĻ
ramp-capacity-2 =Ôēļ
ramp-capacity-3 =ÔēĽ
ramp-capacity-4 =Ôēľ
ramp-capacity-5 =ÔēĹ
ramp-capacity-6 =ÔēŅ
ramp-capacity-7 =ÔĖÄ
ramp-capacity-8 =ÔĖĀ
